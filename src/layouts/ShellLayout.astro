---
import BaseLayout from "./BaseLayout.astro";

type NavLabel = "index" | "writing";

type Props = {
  title: string;
  description: string;
  navLabel: NavLabel;
  crumb: string;
};

const { title, description, navLabel, crumb } = Astro.props;
---

<BaseLayout title={title} description={description} bodyClass="portfolio-page">
  <div class="mobile-bar" role="banner">
    <span class="mobile-name">JEREMIAH</span>
    <button class="mobile-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav">
      menu
    </button>
  </div>
  <div class="mobile-nav" id="mobile-nav" role="navigation" aria-label="Mobile navigation">
    <ul>
      <li>
        <a href="/" class={navLabel === "index" ? "active" : undefined} aria-current={navLabel === "index" ? "page" : undefined}>
          index
        </a>
      </li>
      <li>
        <a href="/posts/" class={navLabel === "writing" ? "active" : undefined} aria-current={navLabel === "writing" ? "page" : undefined}>
          writing
        </a>
      </li>
    </ul>
  </div>

  <div class="shell">
    <aside class="sidebar" role="navigation" aria-label="Site navigation">
      <div class="sidebar-name">JEREMIAH</div>
      <div class="sidebar-handle">// dev · systems · seattle</div>
      <div class="sidebar-rule" aria-hidden="true"></div>

      <ul class="sidebar-nav">
        <li>
          <a href="/" class={navLabel === "index" ? "active" : undefined} aria-current={navLabel === "index" ? "page" : undefined}>
            <span class="arrow">›</span> index
          </a>
        </li>
        <li>
          <a href="/posts/" class={navLabel === "writing" ? "active" : undefined} aria-current={navLabel === "writing" ? "page" : undefined}>
            <span class="arrow">›</span> writing
          </a>
        </li>
      </ul>

      <div class="sidebar-footer">
        <a class="sidebar-link-button" href="/resume_jeremiah_snow.pdf" target="_blank" rel="noreferrer">
          resume ↗
        </a>
        <a class="sidebar-link-button" href="https://www.linkedin.com/in/jlsnow301/" target="_blank" rel="noreferrer">
          linkedin ↗
        </a>
        <a class="sidebar-link-button" href="https://github.com/jlsnow301" target="_blank" rel="noreferrer">
          github ↗
        </a>
      </div>
    </aside>

    <main class="main">
      <div class="pane-header" aria-live="polite" aria-atomic="true">
        <span>~</span>
        <span class="sep">/</span>
        <span class="crumb">{crumb}</span>
      </div>

      <div class="pane-body">
        <slot />
      </div>
    </main>
  </div>

  <script>
    const nav = document.getElementById("mobile-nav");
    const button = document.querySelector(".mobile-toggle");

    if (nav instanceof HTMLElement && button instanceof HTMLButtonElement) {
      button.addEventListener("click", () => {
        const open = nav.classList.toggle("open");
        button.setAttribute("aria-expanded", String(open));
        button.textContent = open ? "close" : "menu";
      });
    }
  </script>
</BaseLayout>
