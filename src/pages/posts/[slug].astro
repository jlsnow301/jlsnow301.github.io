---
import { getCollection, render, type CollectionEntry } from "astro:content";
import ShellLayout from "../../layouts/ShellLayout.astro";
import { formatDate, postTag, sortPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection("blog"));

  return posts.map((post) => {
    return {
      params: { slug: post.id },
      props: { post }
    };
  });
}

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;
const { Content } = await render(post);
---

<ShellLayout
  title={`Jeremiah Snow // ${post.data.title}`}
  description={post.data.description}
  navLabel="writing"
  crumb="writing"
>
  <div class="page-section">
    <div class="prompt">
      <span>jeremiah@station:~$</span>
      <span class="cmd">cat {post.id}.md</span>
      <span class="cursor" aria-hidden="true"></span>
    </div>

    <article class="article-shell">
      <header class="article-header">
        <span class="post-tag">{postTag(post)}</span>
        <h1>{post.data.title}</h1>
        <p class="article-summary">{post.data.description}</p>
        <div class="article-meta">
          <span>{formatDate(post.data.date)}</span>
        </div>
      </header>

      <div class="article-body">
        <Content />
      </div>
    </article>

    <div class="article-actions">
      <a class="back-link" href="/posts/">← back to writing</a>
    </div>
  </div>
</ShellLayout>
